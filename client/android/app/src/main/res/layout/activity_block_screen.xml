<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#111111">

    <TextView
        android:id="@+id/iconText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏳"
        android:textSize="48sp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Screen time ended"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/messageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You have used all your screen time for today."
        android:textSize="18sp"
        android:textColor="#DDDDDD"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/timeDetailsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Used today: 0 / 0 minutes"
        android:textSize="16sp"
        android:textColor="#BBBBBB"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/hintText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Please wait until tomorrow or until your parent unlocks the device"
        android:textSize="15sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    
</LinearLayout>