<!--
    AndroidManifest.xml

    This file defines the main Android app configuration, including:
    - Required permissions
    - Declared activities
    - Declared services
    - Application-level settings

    Main responsibilities:
    - Register the app entry point (MainActivity)
    - Register the blocking screen activity (BlockScreenActivity)
    - Register the AccessibilityService used for parental control enforcement
    - Declare permissions needed for networking, usage stats, and device behavior

    Key components:

    1. Permissions
       - INTERNET:
         Required for communication with the backend server.
       - PACKAGE_USAGE_STATS:
         Required to read app usage statistics for screen-time tracking.
       - SYSTEM_ALERT_WINDOW / VIBRATE / storage permissions:
         Declared as optional here, but should only remain if actually used.

    2. MainActivity
       - Main launcher activity of the React Native / Expo app.
       - Exported because Android must be able to launch it from the launcher.

    3. BlockScreenActivity
       - Full-screen activity shown when the device is blocked.
       - Not exported because it is only used internally by the app.
       - Excluded from recents to prevent user confusion and avoid exposing internal lock flow.

    4. ScreenGuardianAccessibilityService
       - Core native enforcement service of the app.
       - Monitors foreground app changes and enforces screen-time restrictions.
       - Requires BIND_ACCESSIBILITY_SERVICE permission.
       - Uses accessibility_service_config.xml for Android accessibility service settings.

    Security notes:
    - Sensitive internal components should not be exported unless necessary.
    - PACKAGE_USAGE_STATS is a protected permission and must also be manually granted by the user in system settings.

    Important:
    - This manifest is critical for connecting React Native UI, native Android logic,
      and background enforcement behavior into one working application.
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

  <uses-permission android:name="android.permission.INTERNET"/>
  <!-- OPTIONAL PERMISSIONS, REMOVE WHATEVER YOU DO NOT NEED -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
  <uses-permission android:name="android.permission.VIBRATE"/>
  <!-- These require runtime permissions on M -->
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>

  <uses-permission
      android:name="android.permission.PACKAGE_USAGE_STATS"
      tools:ignore="ProtectedPermissions" />
  <!-- END OPTIONAL PERMISSIONS -->


  <queries>
    <!-- Support checking for http(s) links via the Linking API -->
    <intent>
      <action android:name="android.intent.action.VIEW" />
      <category android:name="android.intent.category.BROWSABLE" />
      <data android:scheme="https" />
    </intent>
  </queries>

  <application android:name=".MainApplication" android:label="@string/app_name" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:allowBackup="false" android:theme="@style/AppTheme" android:supportsRtl="true">
    <activity android:name=".MainActivity" android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode" android:launchMode="singleTask" android:windowSoftInputMode="adjustResize" android:theme="@style/Theme.App.SplashScreen" android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
    </activity>

    <activity
    android:name=".BlockScreenActivity"
    android:exported="false"
    android:excludeFromRecents="true"
    android:launchMode="singleTask"
    android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

<service
    android:name=".ScreenGuardianAccessibilityService"
    android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
    android:exported="false">
    <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
    </intent-filter>

    <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/accessibility_service_config" />
</service>
    <meta-data
        android:name="com.google.android.geo.API_KEY"
        android:value="AIzaSyCb55IMFtYh6m-4nj-vlGPiFA3hfruE1Qk" />
  </application>
</manifest>
